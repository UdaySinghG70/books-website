# ── Local (XAMPP) ─────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=booksdb

# ── Production (Railway / PlanetScale) ───────────────────────────────────────
# If your host provides a single DATABASE_URL, uncomment and use db.js option B.
# DATABASE_URL=mysql://user:password@host:port/dbname

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CLIENT_URL=http://localhost:5173
# Production example:
# CLIENT_URL=https://your-app.vercel.app,http://localhost:5173
